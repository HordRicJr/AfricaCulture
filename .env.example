# ============================================================================
#  AfricaCulture Chat — Environment template
#  Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ============================================================================

# ----------------------------------------------------------------------------
#  SERVER-SIDE SECRETS (BFF only)
#  These variables are read ONLY by the Node/Express proxy in /server.
#  They are NOT prefixed with VITE_, so Vite will NEVER bundle them into the
#  browser code. The API key stays on the server.
# ----------------------------------------------------------------------------

# Authentication mode for the BFF -> Foundry calls: "key" or "entra"
FOUNDRY_AUTH_MODE=key

# Resource API key (used when FOUNDRY_AUTH_MODE=key)
FOUNDRY_API_KEY=replace-with-your-foundry-resource-key

# Foundry PROJECT endpoint (used for the agent_reference flow)
FOUNDRY_PROJECT_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT

# Azure OpenAI v1 endpoint (used for the direct-model flow)
FOUNDRY_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/v1

# Which flow to use: "agent" (agent_reference) or "model" (direct deployment)
FOUNDRY_MODE=agent

# Agent reference (used when FOUNDRY_MODE=agent)
FOUNDRY_AGENT_NAME=YOUR-AGENT-NAME
FOUNDRY_AGENT_VERSION=1

# Direct model deployment name (used when FOUNDRY_MODE=model)
FOUNDRY_MODEL=gpt-4.1

# BFF server port
PORT=8787

# Comma-separated list of allowed CORS origins for the BFF
CORS_ORIGINS=http://localhost:5173

# ----------------------------------------------------------------------------
#  CLIENT-SIDE PUBLIC CONFIG (safe to expose — must be prefixed with VITE_)
# ----------------------------------------------------------------------------

# Endpoint the SPA calls. In dev, Vite proxies /api to the BFF (see vite.config.ts).
VITE_CHAT_API_URL=/api/chat
